PORT=3000

# Optional full Postgres URL (overrides host/port/user/password/name when set)
# Example:
# DATABASE_URL=postgresql://quran_api:quran_api@127.0.0.1:5432/quran_french_api
DATABASE_URL=

# Postgres connection settings for local Docker setup
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=quran_api
DB_PASSWORD=quran_api
DB_NAME=quran_french_api

# SSL is usually false for local Docker and true for managed providers
DB_SSL=false

# Optional TypeORM settings
DB_LOGGING=false
DB_POOL_MAX=10
