PORT=3000

# Enable database wiring (set to true when Supabase credentials are configured)
DB_ENABLED=false

# Supabase Postgres connection string
# Example:
# DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
DATABASE_URL=

# Supabase usually requires SSL
DB_SSL=true

# Optional TypeORM settings
DB_LOGGING=false
DB_POOL_MAX=10
